# ============================================
# Polymarket-IB Bridge Configuration
# ============================================

# --- Interactive Brokers ---
IB_USER=your_ib_account_username
IB_PASS=your_ib_account_password
IB_ACCOUNT_ID=DU1234567  # Paper account ID, lub U1234567 dla live
IB_TRADING_MODE=paper  # paper | live
VNC_PASSWORD=changeme  # Do debugowania via VNC

# --- API Connection ---
IB_GATEWAY_HOST=ib-gateway  # lub host.docker.internal
IB_GATEWAY_PORT=4002

# --- Polymarket ---
# Opcjonalnie - API do pollingu (Polymarket ma publiczne API)
POLYMARKET_API_URL=https://gamma-api.polymarket.com

# --- Database ---
DATABASE_URL=sqlite:///data/bridge.db
# Dla PostgreSQL (opcjonalnie):
# DATABASE_URL=postgresql://user:pass@localhost/bridge

# --- Risk Management ---
MAX_DAILY_LOSS_USD=100        # Max strata dziennia, potem STOP
MAX_POSITION_SIZE_USD=50      # Max wartość pojedynczej pozycji
CIRCUIT_BREAKER_ERRORS=5      # Ile błędów przed emergency stop
RATE_LIMIT_MSG_PER_SEC=10     # Max wiadomości do IB per sekundę

# --- Trading Mode ---
# WAŻNE: Zacznij od paper!
PAPER_TRADING=true            # true = symulacja, false = realne zlecenia
AUTO_EXECUTION=false          # true = automatyczne zlecenia, false = tylko alerty

# --- Notifications (wybierz jeden lub więcej) ---

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Discord (łatwiejszy setup)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Email (SMTP)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=app_password
# ALERT_EMAIL=your@email.com

# --- Feature Flags ---
ENABLE_DISCOVERY=true         # Automatyczne discovery kontraktów
ENABLE_CORRELATION=true       # Automatyczne mapowanie
ENABLE_EXECUTION=true         # Wykonywanie zleceń (zależy od PAPER_TRADING)
